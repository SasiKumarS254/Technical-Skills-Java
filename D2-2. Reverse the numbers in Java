public class ReverseNumber {
    public static void main(String[] args) {
        int number = 12345;
        int reversed = 0;
        int temp = number;
        while (temp != 0) {
            int digit = temp % 10;
            reversed = reversed * 10 + digit;
            temp = temp / 10;
        }
        System.out.println("Original number: " + number);
        System.out.println("Reversed number: " + reversed);
    }
}
