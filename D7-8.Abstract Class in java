abstract class Employee{
    abstract void caculateSalary();
}
class Manager extends Employee{
    void caculateSalary(){
        System.out.println("Manager Salary:$8000");
    }
}
class Engineer extends Employee{
    void caculateSalary(){
        System.out.println("Engineer Salary:$5000");
    }
}
class Programmer extends Employee{
    void caculateSalary(){
        System.out.println("Programmer Salary:$6000");
    }
}
class Main{
    public static void main(String[] args){
        Employee m=new Manager();
        Employee e=new Engineer();
        Employee p=new Programmer();
        m.caculateSalary();
        e.caculateSalary();
        p.caculateSalary();
    }
}
