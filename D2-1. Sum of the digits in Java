public class SumOfDigits {
    public static void main(String[] args) {
        int number = 12345;
        int sum = 0;
        int temp = Math.abs(number);
        while (temp > 0) {
            sum = sum + (temp % 10);
            temp = temp / 10; 
        }
        System.out.println("Sum of digits of " + number + " = " + sum);
    }
}
