public class Palindrome {
    public static void main(String[] args) {
        for (int i = 0; i <= 100; i++) {
            int n = i, rev = 0;
            while (n > 0) {
                rev = rev * 10 + n % 10;
                n /= 10;
            }
            if (i == rev) System.out.println(i);
        }
    }
}
