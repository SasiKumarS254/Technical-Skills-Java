class Main {
    public static void main(String[] args) {
        int arr[] = {10, 20, 30, 40, 50};
        int n = arr.length;
        int sum = 0;

        for(int i = 0; i < n; i++) {
            sum += arr[i];
        }

        double avg = (double)sum / n;

        System.out.println(avg);
    }
}
