class Animal{
    void walk(){
        System.out.println("I am Walking");
    }
}
class Birds extends Animal{
    void fly(){
        System.out.println("I am Flying");
    }
    void sing(){
        System.out.println("I am Singing");
    }
}
class main{
    public static void main(String[] args){
        Birds b=new Birds();
        b.walk();
        b.fly();
        b.sing();
    }
}
