class MultiplyFun{
    static int Multiply(int a,int b){
        return a*b;
    }
    static int Multiply(int a,int b,int c){
        return a*b*c;
    }
}
class Main{
    public static void main(String[] args){
        System.out.println(MultiplyFun.Multiply(2,3));
        System.out.println(MultiplyFun.Multiply(2,3,4));
    }
}
